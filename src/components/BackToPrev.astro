---
type Props = {
	href: string;
};

const { href } = Astro.props;
---

<a
	href={href}
	class="group relative flex w-fit flex-nowrap rounded border border-[#46433b] py-1.5 pl-7 pr-3 text-[#46433b] hover:bg-[#46433b] hover:text-[#faf9f6]"
>
	<svg
		xmlns="http://www.w3.org/2000/svg"
		viewBox="0 0 24 24"
		class="absolute left-2 top-1/2 size-4 -translate-y-1/2 fill-none stroke-current stroke-2"
	>
		<line x1="5" y1="12" x2="19" y2="12"></line>
		<polyline points="12 5 5 12 12 19"></polyline>
	</svg>
	<div class="text-sm">
		<slot />
	</div>
</a>
