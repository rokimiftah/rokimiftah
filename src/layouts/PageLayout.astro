---
import Head from "@components/Head.astro";
import { SITE } from "@consts";

type Props = {
	title: string;
};

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<Head title={`${title} - ${SITE.NAME}`} />
	</head>
	<body>
		<main>
			<slot />
		</main>
	</body>
</html>
